@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "مدیریت کاربران";
    Layout = "~/Areas/Admin/Views/_AdminDashboard.cshtml";
}

<script asp-append-version="true" src="~/admin/js/pages/users/users.js"></script>

<div class="main-container container-fluid">
    <!-- Row -->
    <div class="row">
        <div class="col-lg-12 col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><i class="fa fa-users text-primary"></i> کاربران</h3>
                </div>
                <div class="card-body pb-2">

                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <input type="text" id="txt_SearchParam" autocomplete="off" onchange="ChangeUrl(1)" class="form-control" placeholder="جستجو بر اساس کلمه کلیدی" />
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="form-group">
                                <button class="btn btn-primary" onclick="ChangeUrl(1)"><i class="fa fa-search"></i> جستجو</button>
                                <button class="btn btn-danger" onclick="ClearSearch()"><i class="fa fa-eraser"></i> پاک کردن جستجو</button>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive" id="Grid_Div">
                        <table class="table table-hover table-bordered table-striped text-center">
                            <thead>
                                <tr>
                                    <th scope="col">ردیف</th>
                                    <th scope="col">تاریخ ثبت نام</th>
                                    <th scope="col">نام کاربری</th>
                                    <th scope="col">نام و نام خانوادگی</th>
                                    <th scope="col">آخرین ورود</th>
                                    <th scope="col">وضعیت</th>
                                    <th scope="col">عملیات</th>
                                </tr>
                            </thead>
                            <tbody id="tbody_users">
                            </tbody>
                        </table>
                    </div>

                    <ul class="pagination" id="Div_Paging">
                    </ul>

                </div>
            </div>
        </div>

    </div>
    <!-- End Row -->
</div>


<div class="modal fade" id="Modal_ActiveOrDeactive" data-keyboard="false" data-backdrop="static" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="ActiveOrDeactive" data-ajax="true" data-ajax-success="OnSuccessActiveOrDeactive" data-ajax-update="progress" method="post">
                <div class="whz">
                    <input name="userRef" id="txt_userRef" />
                </div>
                <div class="modal-header">
                    <h5 class="modal-title text-danger"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>آیا برای انجام عملیات اطمینان دارید؟</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="$('#Modal_ActiveOrDeactive').modal('hide');"><i class="fa fa-times-circle"></i> خیر</button>
                    <button type="submit"  class="btn btn-primary"><i class="fa fa-check-circle"></i> بله</button>
                </div>

            </form>
        </div>
    </div>
</div>