                                <div class="col-md-6 mb-4">
                                    <input class="form-control" type="text" placeholder="نام *" required>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <input class="form-control text-left" type="email" placeholder="ایمیل *" required>
                                </div>
                                <div class="col-12 mb-4">
                                    <textarea class="form-control" required
                                              placeholder="متن*"></textarea>
                                </div>
                            </div>
                            <button class="btn btn-gold btn-rounded btn-block">
                                ارسال پیام
                            </button>
                        </form>
                    </div>
                </div>
            </div>
