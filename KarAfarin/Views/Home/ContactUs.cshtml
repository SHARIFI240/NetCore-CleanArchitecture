                                </div>
                            </div>
                            <div class="icon-box icon-box-side">
                                <span class="icon-box-icon">
                                    <i class="fa fa-phone"></i>
                                </span>
                                <div class="icon-box-content rtl">
                                    <h4 class="icon-box-title">تلفن</h4>
                                    <p>
                                        <a href="tel:#"> 0912345678 </a><br>
                                        <a href="tel:#"> 0912345678 </a>
                                    </p>
                                </div>
                            </div>
                            <div class="icon-box icon-box-side">
                                <span class="icon-box-icon">
                                    <i class="fa fa-envelope"></i>
                                </span>
                                <div class="icon-box-content rtl">
                                    <h4 class="icon-box-title">ایمیل </h4>
                                    <p>
                                        <a href="mailto:info@karafarin.app">info@karafarin.app</a><br>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mb-4">
